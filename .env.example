# Telegram
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
ADMIN_IDS=123456789
ALLOW_MODE=all

# TMDB
TMDB_TOKEN=0123456789abcdef0123456789abcdef
TMDB_LANGUAGE=ru-RU
TMDB_CACHE_TTL=86400

# Polling / network
POLL_SECONDS=120
REQUEST_TIMEOUT=60
SOURCE_FETCH_LIMIT=200

# PostgreSQL (compose internal service)
POSTGRES_DB=kinozal_news
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password_please_2026
DATABASE_URL=postgresql://postgres:change_this_password_please_2026@postgres:5432/kinozal_news

# Redis
REDIS_URL=redis://kinozal-redis:6379/0

# Delivery / UI
DISABLE_WEB_PAGE_PREVIEW=1
BOOTSTRAP_AS_READ=1
DEEP_LINK_BOT_USERNAME=kinozaltestbot

# Cleanup / maintenance
CLEANUP_DUPLICATES_PREVIEW_LIMIT=20
CLEANUP_VERSIONS_PREVIEW_LIMIT=20
CLEANUP_VERSIONS_KEEP_LAST=3

# Startup resilience
STARTUP_DB_RETRIES=30
STARTUP_DB_RETRY_DELAY=2
