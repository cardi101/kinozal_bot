# Telegram
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
ADMIN_IDS=123456789
ALLOW_MODE=open

# Kinozal credentials
KINOZAL_USERNAME=your_kinozal_login
KINOZAL_PASSWORD=your_kinozal_password

# TMDB
TMDB_TOKEN=0123456789abcdef0123456789abcdef
TMDB_LANGUAGE=ru-RU
TMDB_CACHE_TTL=86400
TMDB_NEGATIVE_CACHE_TTL=21600

# Polling / network
POLL_SECONDS=120
REQUEST_TIMEOUT=60
SOURCE_FETCH_LIMIT=200

# PostgreSQL (compose internal service)
POSTGRES_DB=kinozal_news
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password_please
POSTGRES_VOLUME_NAME=kinozal_bot_postgres_data
DATABASE_URL=postgresql://postgres:change_this_password_please@postgres:5432/kinozal_news

# Redis
REDIS_URL=redis://redis:6379/0

# Delivery / UI
DISABLE_WEB_PAGE_PREVIEW=1
BOOTSTRAP_AS_READ=1
DEEP_LINK_BOT_USERNAME=kinozaltestbot

# Magnet links (optional — requires public domain with HTTPS)
# MAGNET_BASE_URL=https://magnet.example.com
# MAGNET_WEB_PORT=8081

# Anime resolver (optional)
ANIME_RESOLVER_ENABLED=0
ANIME_RESOLVER_LOG_ONLY=1
# ANIME_MAPPINGS_DIR=data/anime-mappings

# Source health alerts
SOURCE_ERROR_ALERT_THRESHOLD=3
SOURCE_ERROR_ALERT_REPEAT_MINUTES=180

# Sentry (optional)
# SENTRY_DSN=https://public_key@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_RELEASE=

# Cleanup / maintenance
CLEANUP_DUPLICATES_PREVIEW_LIMIT=20
CLEANUP_VERSIONS_PREVIEW_LIMIT=20
CLEANUP_VERSIONS_KEEP_LAST=3

# Startup resilience
STARTUP_DB_RETRIES=30
STARTUP_DB_RETRY_DELAY=2

# HTTP API (optional)
API_HOST=0.0.0.0
API_PORT=8000
# ADMIN_HTTP_TOKEN=change_me_for_admin_endpoints
